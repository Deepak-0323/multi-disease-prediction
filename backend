from fastapi import FastAPI
from pydantic import BaseModel
import joblib
import numpy as np

app = FastAPI()

# Load models
diabetes_model = joblib.load("models/diabetes_model.pkl")
heart_model = joblib.load("models/heart_model.pkl")
kidney_model = joblib.load("models/kidney_model.pkl")

# =========================
# Input Schemas
# =========================

class DiabetesInput(BaseModel):
    features: list

class HeartInput(BaseModel):
    features: list

class KidneyInput(BaseModel):
    features: list

# =========================
# Routes
# =========================

@app.get("/")
def home():
    return {"message": "Multi-Disease Prediction API Running"}

@app.post("/predict/diabetes")
def predict_diabetes(data: DiabetesInput):
    try:
        input_data = np.array(data.features).reshape(1, -1)
        prediction = diabetes_model.predict(input_data)[0]
        return {"diabetes_prediction": int(prediction)}
    except Exception as e:
        return {"error": str(e)}

@app.post("/predict/heart")
def predict_heart(data: HeartInput):
    try:
        input_data = np.array(data.features).reshape(1, -1)
        prediction = heart_model.predict(input_data)[0]
        return {"heart_prediction": int(prediction)}
    except Exception as e:
        return {"error": str(e)}

@app.post("/predict/kidney")
def predict_kidney(data: KidneyInput):
    try:
        input_data = np.array(data.features).reshape(1, -1)
        prediction = kidney_model.predict(input_data)[0]
        return {"kidney_prediction": int(prediction)}
    except Exception as e:
        return {"error": str(e)}
